# MongoDB Atlas connection URI
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/nursery_db

# Port the Spring Boot server listens on
SERVER_PORT=3000

# Groq LLM API (free key at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# HuggingFace Inference API (free token at https://huggingface.co/settings/tokens)
HUGGINGFACE_API_TOKEN=hf_your_huggingface_token_here
